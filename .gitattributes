* text=auto eol=lf

# Source, scripts, build metadata, and docs.
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
.clang-format text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# SVGs are text assets and should diff normally.
*.svg text eol=lf

# Raster/image and binary data assets.
*.bmp binary
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.ppm binary
*.bin binary
*.mat binary
*.xls binary
*.xlsx binary
